# =============================================================================
# ITFlow — Variables de entorno
# Copiar a .env y completar antes de levantar el stack
# =============================================================================

# Base de datos
DB_NAME=itflow
DB_USER=itflow
DB_PASS=cambia_esto_por_password_seguro
DB_ROOT_PASS=cambia_esto_por_root_password_seguro

# URL pública de la aplicación (sin https://, sin barra final)
# Debe coincidir exactamente con el dominio apuntado al servidor
APP_URL=itflow.tudominio.com

# Nombre de la app (aparece en el título del navegador)
APP_NAME=ITFlow

# Setup wizard
# 1 = activo (primera vez)
# 0 = deshabilitado (ya completaste el setup, cambiar a 0 y reiniciar)
SETUP_ENABLED=1

# ID de instalación (se genera automáticamente si se deja vacío)
INSTALLATION_ID=
